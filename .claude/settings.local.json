{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_HOOK_ARCHITECTURE_COMPLIANCE_ENABLED": "0",
    "CLAUDE_HOOK_DEBUG": "0",
    "CLAUDE_HOOK_ENFORCEMENT_MARKDOWN_LINT": "warn",
    "CLAUDE_HOOK_INJECT_BEST_PRACTICES_ENABLED": "1",
    "CLAUDE_HOOK_INJECT_CITATION_CONTEXT_ENABLED": "1",
    "CLAUDE_HOOK_INJECT_CURRENT_DATE_ENABLED": "1",
    "CLAUDE_HOOK_LOG_EVENTS_ENABLED": "0",
    "CLAUDE_HOOK_LOG_LEVEL": "info",
    "CLAUDE_HOOK_LOG_NOTIFICATION_ENABLED": "1",
    "CLAUDE_HOOK_LOG_PERMISSIONREQUEST_ENABLED": "1",
    "CLAUDE_HOOK_LOG_POSTTOOLUSE_ENABLED": "1",
    "CLAUDE_HOOK_LOG_PRECOMPACT_ENABLED": "1",
    "CLAUDE_HOOK_LOG_PRETOOLUSE_ENABLED": "1",
    "CLAUDE_HOOK_LOG_RETENTION_MAX_AGE_DAYS": "30",
    "CLAUDE_HOOK_LOG_ROTATION_ENABLED": "1",
    "CLAUDE_HOOK_LOG_ROTATION_MAX_SIZE_MB": "10",
    "CLAUDE_HOOK_LOG_SESSIONEND_ENABLED": "1",
    "CLAUDE_HOOK_LOG_SESSIONSTART_ENABLED": "1",
    "CLAUDE_HOOK_LOG_STOP_ENABLED": "1",
    "CLAUDE_HOOK_LOG_SUBAGENTSTOP_ENABLED": "1",
    "CLAUDE_HOOK_LOG_USERPROMPTSUBMIT_ENABLED": "1",
    "CLAUDE_HOOK_LOG_VERBOSITY": "summary",
    "CLAUDE_HOOK_MARKDOWN_LINT_ENABLED": "0",
    "CLAUDE_HOOK_PREVENT_BACKUP_FILES_ENABLED": "1",
    "CLAUDE_HOOK_SUGGEST_DOCS_DELEGATION_ENABLED": "1",
    "CLAUDE_HOOK_SUGGEST_GEMINI_DOCS_ENABLED": "1",
    "ENABLE_LSP_TOOL": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(test:*)",
      "Edit",
      "Glob",
      "Grep",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__get_network_request",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__context7",
      "mcp__firecrawl",
      "mcp__microsoft-learn",
      "mcp__perplexity__reason",
      "mcp__perplexity",
      "mcp__ref",
      "Read",
      "Skill",
      "Task",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(./.env.*)",
      "Read(./.env)",
      "Read(./.envrc)",
      "Read(./**/*.cer)",
      "Read(./**/*.crt)",
      "Read(./**/*.jks)",
      "Read(./**/*.key)",
      "Read(./**/*.keystore)",
      "Read(./**/*.p12)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/credentials.json)",
      "Read(./**/id_dsa)",
      "Read(./**/id_ecdsa)",
      "Read(./**/id_ed25519.*)",
      "Read(./**/id_ed25519)",
      "Read(./**/id_rsa.*)",
      "Read(./**/id_rsa)",
      "Read(./credentials.json)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/**)"
    ],
    "ask": [],
    "defaultMode": "acceptEdits"
  }
}